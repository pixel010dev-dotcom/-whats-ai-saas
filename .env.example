# ===========================================
# WhatsAI - Variáveis de Ambiente
# ===========================================
# Copie este arquivo para .env e preencha os valores
# Após configurar, execute: npx prisma generate

# --- Banco de Dados (Supabase PostgreSQL) ---
DATABASE_URL="postgresql://postgres:password@db.xxxxxxxxxx.supabase.co:5432/postgres"

# --- Supabase (Auth + Storage) ---
# Estas são as variáveis do lado do servidor
SUPABASE_URL=""
SUPABASE_SERVICE_KEY=""
SUPABASE_ANON_KEY=""

# Estas são as variáveis públicas (acessíveis pelo client-side)
# IMPORTANTE: Preencha com os mesmos valores do SUPABASE_URL e SUPABASE_ANON_KEY
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# --- Mercado Pago (Pagamentos) ---
# Obtenha em: https://www.mercadopago.com.br/developers/panel
MERCADO_PAGO_ACCESS_TOKEN=""
MERCADO_PAGO_WEBHOOK_SECRET=""

# --- URL da Aplicação ---
# Em produção, altere para a URL do seu domínio (ex: https://whatsai.seudominio.com)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Evolution API (WhatsApp) ---
# Necessário instalar a Evolution API separadamente
# Docs: https://doc.evolution-api.com/
EVOLUTION_API_URL=""
EVOLUTION_API_KEY=""

# --- Provedores de IA (Fallback automático) ---
# O sistema tenta cada provedor em ordem até obter resposta
# Pelo menos UM precisa estar configurado

# OpenCode Zen
OPENCODE_ZEN_BASE_URL="https://api.opencode.ai/v1"
OPENCODE_ZEN_API_KEY=""

# OpenRouter (recomendado como principal - suporta GPT, Claude, etc)
OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"
OPENROUTER_API_KEY=""

# Groq (rápido e gratuito)
GROQ_API_KEY=""

# Cerebras
CEREBRAS_API_KEY=""

# Mistral
MISTRAL_API_KEY=""
