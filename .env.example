# ===========================================
# WhatsAI - Variáveis de Ambiente
# ===========================================
# Copie este arquivo para .env e preencha os valores
# Após configurar, execute: npx prisma generate

# --- Banco de Dados (Supabase PostgreSQL) ---
DATABASE_URL="postgresql://postgres:***@db.xxxxxxxxxx.supabase.co:5432/postgres"

# --- Supabase (Auth + Storage) ---
SUPABASE_URL=""
SUPABASE_SERVICE_KEY=""
SUPABASE_ANON_KEY=""
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# --- Mercado Pago (Pagamentos) ---
MERCADO_PAGO_ACCESS_TOKEN=""
MERCADO_PAGO_WEBHOOK_SECRET=""

# --- URL da Aplicação ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Evolution API (WhatsApp) ---
EVOLUTION_API_URL=""
EVOLUTION_API_KEY=""

# --- Provedores de IA (Fallback automático) ---
# Ordem de tentativa: OpenRouter > Groq > Cerebras > Gemini > Mistral > OpenCode Zen > DeepSeek
# Pelo menos UM precisa estar configurado. Recomendo configurar todos para máxima resiliência.

# OpenRouter (recomendado como principal - Gemini 2.5 Flash)
OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"
OPENROUTER_API_KEY=""

# Groq (rápido e gratuito - Llama 3.3 70B)
GROQ_API_KEY=""

# Cerebras (gratuito - Gemma 4 31B)
CEREBRAS_API_KEY=""

# Google Gemini (API direta - 1500 req/dia grátis)
GEMINI_API_KEY=""

# Mistral
MISTRAL_API_KEY=""

# DeepSeek
DEEPSEEK_API_KEY=""

# OpenCode Zen (DeepSeek V4 Flash Free - 100% grátis, último recurso)
OPENCODE_ZEN_BASE_URL="https://opencode.ai/zen/v1"
OPENCODE_ZEN_API_KEY=""

# --- Cron ---
CRON_SECRET=""
